{
	"name": "Sparkle",
	"short_name": "Sparkle",
	"description": "A cozy watch-party app for rooms, chat, media, and games.",
	"id": "/",
	"start_url": "/",
	"scope": "/",
	"display": "standalone",
	"display_override": ["window-controls-overlay", "standalone", "browser"],
	"orientation": "any",
	"background_color": "#08090d",
	"theme_color": "#08090d",
	"categories": ["entertainment", "social"],
	"prefer_related_applications": false,
	"icons": [
		{
			"src": "/favicon/android-icon-192x192.png",
			"sizes": "192x192",
			"type": "image/png",
			"purpose": "any"
		},
		{
			"src": "/favicon/icon-512x512.png",
			"sizes": "512x512",
			"type": "image/png",
			"purpose": "any"
		},
		{
			"src": "/favicon/icon-maskable-512x512.png",
			"sizes": "512x512",
			"type": "image/png",
			"purpose": "maskable"
		}
	],
	"shortcuts": [
		{
			"name": "New Room",
			"short_name": "New",
			"description": "Start a new Sparkle room.",
			"url": "/rooms/new",
			"icons": [
				{
					"src": "/favicon/android-icon-192x192.png",
					"sizes": "192x192",
					"type": "image/png"
				}
			]
		}
	]
}
