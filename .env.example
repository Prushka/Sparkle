SERVER_BE=/be
SERVER_STATIC=/static
# Optional. Use this when SERVER_BE is relative but SSR should fetch the
# backend directly instead of through the current request host.
SERVER_INTERNAL_BE=http://localhost:1323
# Optional. Defaults to SERVER_INTERNAL_BE/static when SERVER_INTERNAL_BE is set.
SERVER_INTERNAL_STATIC=http://localhost:1323/static
PUBLIC_DISCORD_CLIENT_ID=
SERVER_DISCORD_CLIENT_SECRET=

# For Discord Activities, the pathnames in SERVER_BE and SERVER_STATIC should
# match Activity URL Mapping prefixes, for example /be and /static.

# Backend
ADDR=:1323
OUTPUT=./output
JOBS_CACHE_TTL=15m
MAX_PFP_BYTES=12000000
